# ===== SERVER ENVIRONMENT =====

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/soummamcar

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password hashing
BCRYPT_ROUNDS=12

# SATIM (CIB/Edahabia) — Algerian payment gateway
SATIM_MERCHANT_ID=your-merchant-id
SATIM_TERMINAL_ID=your-terminal-id
SATIM_SECRET_KEY=your-secret-key
SATIM_API_URL=https://epay.satim.dz/payment/merchants

# Stripe (diaspora payments)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CURRENCY=eur

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=reservations@soummamcar.dz

# WhatsApp Business API
WHATSAPP_API_TOKEN=your-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-id
WHATSAPP_BUSINESS_ID=your-business-id

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+213xxx

# Storage (S3-compatible: Cloudflare R2, AWS S3, MinIO)
S3_ENDPOINT=your-endpoint
S3_BUCKET=soummamcar-files
S3_ACCESS_KEY=your-key
S3_SECRET_KEY=your-secret
S3_REGION=auto

# Exchange Rate API
EXCHANGE_RATE_API_URL=https://api.frankfurter.dev/v1/latest

# App
APP_URL=https://soummamcar.dz
FRONTEND_URL=http://localhost:8080
ADMIN_EMAIL=admin@soummamcar.dz
PORT=3000
NODE_ENV=development
